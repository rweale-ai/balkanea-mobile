{
  "expo": {
    "name": "balkanea-mobile",
    "slug": "balkanea-mobile",
    "scheme": "balkanea",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marraglobal.balkanea",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Balkanea uses your microphone to let you plan trips by voice with Bea."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.marraglobal.balkanea",
      "permissions": ["RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS", "INTERNET"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "@config-plugins/react-native-webrtc"
    ]
  }
}
